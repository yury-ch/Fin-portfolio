---
title: "Delta Price Sync — _delta_sync()"
---
flowchart TD
    START(["_delta_sync\ntickers, period, existing_df"])

    START --> LAST["last_ts = existing_df.index.max()"]

    LAST --> NATCHECK{"last_ts is NaT?\n(empty cache)"}
    NATCHECK -- "yes  (edge case)" --> FETCH_EMPTY["fetch_prices(start=NaT)\nreturns empty DataFrame"]
    FETCH_EMPTY --> RETURN_EMPTY["return existing_df unchanged\n(empty)"]

    NATCHECK -- no --> WINDOW["start = last_ts − buffer_days\n(default 5 days overlap)"]
    WINDOW --> FETCH["YahooPriceLoader.fetch_prices(\n  tickers,\n  interval=interval,\n  start=start,\n  end=now\n)"]

    FETCH --> EMPTY{"delta_df empty?\n(Yahoo outage / no new data)"}
    EMPTY -- yes --> SAFE["return existing_df unchanged\n✅ cache preserved"]
    EMPTY -- no --> CONCAT["pd.concat([existing_df, delta_df])"]

    CONCAT --> DEDUP["drop_duplicates(keep='last')\n⚠️ new data wins on overlap\n(corrections & corporate actions)"]
    DEDUP --> SORT["sort_index() ascending"]
    SORT --> TRIM["trim_history(merged, period)\nkeep rows ≥ now − horizon\nif result empty → keep tail(1)"]
    TRIM --> DONE(["return trimmed_df\nwritten to Parquet by caller"])

    classDef decision fill:#fef9c3,stroke:#ca8a04,color:#422006
    classDef safe     fill:#dcfce7,stroke:#16a34a,color:#14532d
    classDef danger   fill:#fee2e2,stroke:#dc2626,color:#7f1d1d
    classDef neutral  fill:#f1f5f9,stroke:#94a3b8,color:#1e293b
    classDef io       fill:#dbeafe,stroke:#3b82f6,color:#1e3a5f

    class NATCHECK,EMPTY decision
    class SAFE,RETURN_EMPTY safe
    class DEDUP danger
    class CONCAT,SORT,TRIM neutral
    class START,DONE,FETCH,FETCH_EMPTY io
