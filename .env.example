# Copy this file to .env and adjust for your environment.
# All variables are optional — defaults shown here are used when absent.

# Service URLs (used by the Streamlit UI to reach the FastAPI microservices)
DATA_SERVICE_URL=http://localhost:8001
CALC_SERVICE_URL=http://localhost:8002
TICKER_SERVICE_URL=http://localhost:8000

# Data directory for price/analysis parquet cache
SP500_DATA_DIR=./sp500_data

# Service ports (used by docker-compose port mapping)
TICKER_PORT=8000
DATA_PORT=8001
CALC_PORT=8002
UI_PORT=8501
